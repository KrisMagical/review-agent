# ReviewAgent Docker environment example.
# ReviewAgent is local-first and offline by default.
# Copy this file to .env and fill only the values you actually need.

# Dashboard
REVIEWAGENT_DASHBOARD_HOST=0.0.0.0
REVIEWAGENT_DASHBOARD_PORT=8080

# Database
REVIEWAGENT_DB_PATH=/data/reviewagent.db

# Auth
# Defaults are intentionally open for local development. Enable auth before
# exposing the dashboard outside your machine or trusted private network.
REVIEWAGENT_AUTH_ENABLED=false
REVIEWAGENT_ADMIN_USERNAME=admin
REVIEWAGENT_ADMIN_PASSWORD=
REVIEWAGENT_SESSION_SECRET=
REVIEWAGENT_API_KEYS=
REVIEWAGENT_COOKIE_SECURE=false
REVIEWAGENT_BASIC_AUTH_ENABLED=false

# Hosted Review Web UI
REVIEWAGENT_ALLOWED_REVIEW_ROOTS=/workspace
REVIEWAGENT_MAX_UPLOAD_BYTES=5242880

# Optional GitHub PR review from Web UI
GITHUB_TOKEN=

# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_NAME=ReviewAgent
REVIEWAGENT_GITHUB_HOST=0.0.0.0
REVIEWAGENT_GITHUB_PORT=8000
REVIEWAGENT_GITHUB_ENABLE_INLINE_COMMENTS=true
REVIEWAGENT_GITHUB_ENABLE_SUMMARY_COMMENT=true
REVIEWAGENT_GITHUB_SAVE_RESULTS=true
REVIEWAGENT_GITHUB_REVIEW_MODE=diff_only
REVIEWAGENT_GITHUB_ENABLE_AGENTS=false
REVIEWAGENT_GITHUB_ENABLE_LLM=false
REVIEWAGENT_GITHUB_MAX_INLINE_COMMENTS=30
REVIEWAGENT_GITHUB_MAX_PROJECT_FILES=2000
REVIEWAGENT_GITHUB_MAX_FILE_BYTES=2097152
REVIEWAGENT_GITHUB_MAX_PROJECT_BYTES=52428800
REVIEWAGENT_GITHUB_FETCH_TIMEOUT_SECONDS=30
REVIEWAGENT_GITHUB_ALLOW_NETWORK=false
REVIEWAGENT_GITHUB_ALLOW_LLM=false
REVIEWAGENT_GITHUB_CODE_SHARING_MODE=none

# LLM Providers
REVIEWAGENT_LLM_PROVIDER=none
REVIEWAGENT_LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REVIEWAGENT_ANTHROPIC_MODEL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
REVIEWAGENT_OPENAI_COMPATIBLE_BASE_URL=
REVIEWAGENT_OPENAI_COMPATIBLE_API_KEY=
REVIEWAGENT_OLLAMA_BASE_URL=http://host.docker.internal:11434
REVIEWAGENT_ENTERPRISE_LLM_BASE_URL=
REVIEWAGENT_ENTERPRISE_LLM_API_KEY=

# Network Policy
# Real LLM providers require explicit network authorization.
REVIEWAGENT_NETWORK_ENABLED=false
REVIEWAGENT_ALLOW_LLM=false
REVIEWAGENT_ALLOW_GITHUB_API=false
REVIEWAGENT_CODE_SHARING_MODE=none

# Docker ports
REVIEWAGENT_DOCKER_DASHBOARD_PORT=8080
REVIEWAGENT_DOCKER_GITHUB_PORT=8000

# GitHub private key note:
# The current app reads GITHUB_PRIVATE_KEY directly from the environment.
# For Docker Compose, either keep escaped newlines in .env or inject the
# variable from your deployment secret manager. Do not bake private keys into
# the image.
