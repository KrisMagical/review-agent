# MagicReview Docker environment example.
# MagicReview is local-first and offline by default.
# Copy this file to .env and fill only the values you actually need.

# Dashboard
MGREVIEW_DASHBOARD_HOST=0.0.0.0
MGREVIEW_DASHBOARD_PORT=8080

# Database
MGREVIEW_DB_PATH=/data/magicreview.db

# Auth
# Defaults are intentionally open for local development. Enable auth before
# exposing the dashboard outside your machine or trusted private network.
MGREVIEW_AUTH_ENABLED=false
MGREVIEW_ADMIN_USERNAME=admin
MGREVIEW_ADMIN_PASSWORD=
MGREVIEW_SESSION_SECRET=
MGREVIEW_API_KEYS=
MGREVIEW_COOKIE_SECURE=false
MGREVIEW_BASIC_AUTH_ENABLED=false

# Hosted Review Web UI
MGREVIEW_ALLOWED_REVIEW_ROOTS=/workspace
MGREVIEW_MAX_UPLOAD_BYTES=5242880

# Optional GitHub PR review from Web UI
GITHUB_TOKEN=

# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_NAME=MagicReview
MGREVIEW_GITHUB_HOST=0.0.0.0
MGREVIEW_GITHUB_PORT=8000
MGREVIEW_GITHUB_ENABLE_INLINE_COMMENTS=true
MGREVIEW_GITHUB_ENABLE_SUMMARY_COMMENT=true
MGREVIEW_GITHUB_SAVE_RESULTS=true
MGREVIEW_GITHUB_REVIEW_MODE=diff_only
MGREVIEW_GITHUB_ENABLE_AGENTS=false
MGREVIEW_GITHUB_ENABLE_LLM=false
MGREVIEW_GITHUB_MAX_INLINE_COMMENTS=30
MGREVIEW_GITHUB_MAX_PROJECT_FILES=2000
MGREVIEW_GITHUB_MAX_FILE_BYTES=2097152
MGREVIEW_GITHUB_MAX_PROJECT_BYTES=52428800
MGREVIEW_GITHUB_FETCH_TIMEOUT_SECONDS=30
MGREVIEW_GITHUB_ALLOW_NETWORK=false
MGREVIEW_GITHUB_ALLOW_LLM=false
MGREVIEW_GITHUB_CODE_SHARING_MODE=none

# LLM Providers
MGREVIEW_LLM_PROVIDER=none
MGREVIEW_LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MGREVIEW_ANTHROPIC_MODEL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
MGREVIEW_OPENAI_COMPATIBLE_BASE_URL=
MGREVIEW_OPENAI_COMPATIBLE_API_KEY=
MGREVIEW_OLLAMA_BASE_URL=http://host.docker.internal:11434
MGREVIEW_ENTERPRISE_LLM_BASE_URL=
MGREVIEW_ENTERPRISE_LLM_API_KEY=

# Network Policy
# Real LLM providers require explicit network authorization.
MGREVIEW_NETWORK_ENABLED=false
MGREVIEW_ALLOW_LLM=false
MGREVIEW_ALLOW_GITHUB_API=false
MGREVIEW_CODE_SHARING_MODE=none

# Docker ports
MGREVIEW_DOCKER_DASHBOARD_PORT=8080
MGREVIEW_DOCKER_GITHUB_PORT=8000

# GitHub private key note:
# The current app reads GITHUB_PRIVATE_KEY directly from the environment.
# For Docker Compose, either keep escaped newlines in .env or inject the
# variable from your deployment secret manager. Do not bake private keys into
# the image.
